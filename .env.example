# ── OpenRouter ─────────────────────────────────────────────────────────────
# Get key: https://openrouter.ai/keys
# Free models: google/gemini-flash-1.5-8b | mistralai/mistral-7b-instruct:free
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-flash-1.5-8b

# ── Search ─────────────────────────────────────────────────────────────────
# Search Provider — "searxng" (free, self-hosted) or "serper" (paid)
SEARCH_PROVIDER=searxng
SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_SECRET_KEY=changethissecretkey123

# Get key: https://serper.dev (2500 free searches)
# SERPER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SMTP Email Accounts ────────────────────────────────────────────────────
# Use Gmail App Passwords — NOT your actual Gmail password
# Enable 2FA on Gmail → App Passwords → Generate one per account
# Add multiple accounts for rotation (more accounts = more daily volume)
EMAIL_ACCOUNTS=[{"email":"outreach1@gmail.com","password":"xxxx xxxx xxxx xxxx","smtp_host":"smtp.gmail.com","smtp_port":587},{"email":"outreach2@gmail.com","password":"xxxx xxxx xxxx xxxx","smtp_host":"smtp.gmail.com","smtp_port":587}]
EMAIL_DAILY_LIMIT_PER_ACCOUNT=80
EMAIL_DELAY_SECONDS=45

# ── Tracking ───────────────────────────────────────────────────────────────
# Your domain where tracking pixel endpoint is hosted
TRACKING_BASE_URL=https://track.yourdomain.com
WEBHOOK_SECRET=your_random_secret_here

# ── Campaign Defaults ──────────────────────────────────────────────────────
DEFAULT_NICHE=CA firms
DEFAULT_LOCATION=Mumbai, India
MAX_EMAILS_PER_DAY=3000
BATCH_SIZE=50

# ── Storage ────────────────────────────────────────────────────────────────
BUSINESSES_CSV=data/businesses.csv
CONTACTS_CSV=data/contacts.csv
EMAILS_SENT_CSV=data/emails_sent.csv
RESULTS_CSV=data/results.csv

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log

# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=False

# ── Supabase Database ─────────────────────────────────────────────────────
# Supabase - Direct connection (port 5432) - used ONLY for Alembic migrations
# Get from: Supabase Dashboard > Project Settings > Database > Connection String > Direct
DATABASE_URL_MIGRATIONS=postgresql://postgres:[password]@db.xxxxx.supabase.co:5432/postgres

# Supabase - Pooler connection (port 6543) - used by the app at runtime
# Get from: Supabase Dashboard > Project Settings > Database > Connection String > Pooler (Transaction mode)
DATABASE_URL=postgresql+asyncpg://postgres.xxxxx:[password]@aws-0-region.pooler.supabase.com:6543/postgres

POSTGRES_PASSWORD=password